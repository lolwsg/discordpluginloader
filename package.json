{
  "name": "discord-plugin-loader",
  "version": "1.0.0",
  "description": "Discord client plugin loader similar to Vencord",
  "main": "cli.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:watch": "node scripts/build.js --watch",
    "install:discord": "node cli.js install",
    "uninstall:discord": "node cli.js uninstall",
    "dev": "npm run build && npm run install:discord && npm run build:watch",
    "clean": "node scripts/clean.js"
  },
  "dependencies": {
    "@electron/asar": "^3.2.8",
    "fs-extra": "^11.2.0",
    "chokidar": "^3.5.3"
  }
}